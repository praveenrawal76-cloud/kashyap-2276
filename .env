# KOTAK API Configuration
KOTAK_MERCHANT_ID=your_merchant_id_here
KOTAK_API_KEY=your_api_key_here
KOTAK_API_SECRET=your_api_secret_here
KOTAK_BASE_URL=https://api.kotak.com
KOTAK_ENVIRONMENT=development
KOTAK_TIMEOUT=30000
KOTAK_RETRY_ATTEMPTS=3
KOTAK_LOG_LEVEL=info

# Database Configuration (if needed)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kotak_db
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# Server Configuration
SERVER_PORT=3000
NODE_ENV=development
